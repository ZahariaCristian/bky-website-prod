    <script>
 document.addEventListener('DOMContentLoaded', function() {
    const totalCostElement = document.getElementById('totalCost');
    const checkboxes = document.querySelectorAll('input[type="checkbox"]');
    const toggleTableBtn = document.getElementById('toggleTableBtn');
    const costTableContainer = document.getElementById('costTableContainer');
    const costTableBody = document.getElementById('costTableBody');
    let listinoData = []; // Global variable for listino data

    // Function to fetch listino data from the server
    async function fetchListinoData() {
        try {
            const response = await fetch('/gestPagamenti/getListino', {
                method: 'GET',
                headers: {
                    'Content-Type': 'application/json',
                },
                credentials: 'include',
            });

            if (!response.ok) {
                throw new Error(`HTTP error! Status: ${response.status}`);
            }

            const data = await response.json();
            return data.listino || [];
        } catch (error) {
            console.error('Error fetching listino data:', error);
            return [];
        }
    }

    // Function to count dynamically added fields for 10x1, 10x3, and 10x7
    function countDynamicFields(promoType) {
        const container = document.querySelector(`#tab${promoType} .post-list`);
        return container ? container.children.length : 0;
    }

    function getPromoTypeName(promoType) {
        const names = {
            '1x1': '1x1 (Singola uscita)',
            '1x3': '1x3 (3 uscite)',
            '1x7': '1x7 (7 uscite)',
            '10x1': '10x1 (10 uscite singole)',
            '10x3': '10x3 (10 uscite da 3)',
            '10x7': '10x7 (10 uscite da 7)',
            'supertop': 'SuperTop',
            'highlight': 'Highlight',
            'etichetta': 'Etichetta',
            'supertopnotte': 'SuperTop Notte',
            'highlightnotte': 'Highlight Notte',
            'etichettanotte': 'Etichetta Notte'
        };
        return names[promoType] || promoType;
    }

    function getSelectedPromos() {
        const selectedPromos = {
            '1x1': 0,
            '1x3': 0,
            '1x7': 0,
            '10x1': 0,
            '10x3': 0,
            '10x7': 0,
            'supertop': 0,
            'highlight': 0,
            'etichetta': 0,
            'supertopnotte': 0,
            'highlightnotte': 0,
            'etichettanotte': 0
        };

        // Count standard time slots (1x1, 1x3, 1x7) from checkboxes
        checkboxes.forEach(checkbox => {
            if (checkbox.checked) {
                const id = checkbox.id;
                const promoType = id.slice(0, 3);
                if (selectedPromos.hasOwnProperty(promoType)) {
                    selectedPromos[promoType]++;
                }
            }
        });

        // Count special promos from newpost-panel elements
        document.querySelectorAll('.newpost-panel').forEach(panel => {
            if (panel.dataset.highlight === 'true') selectedPromos.highlight++;
            if (panel.dataset.etichetta === 'true') selectedPromos.etichetta++;
            if (panel.dataset.supertop === 'true') selectedPromos.supertop++;
            if (panel.dataset.highlightnotte === 'true') selectedPromos.highlightnotte++;
            if (panel.dataset.etichettanotte === 'true') selectedPromos.etichettanotte++;
            if (panel.dataset.supertopnotte === 'true') selectedPromos.supertopnotte++;
        });

        // Count dynamically added fields for 10x1, 10x3, and 10x7
        selectedPromos['10x1'] = countDynamicFields('10x1');
        selectedPromos['10x3'] = countDynamicFields('10x3');
        selectedPromos['10x7'] = countDynamicFields('10x7');

        return selectedPromos;
    }

    function updateCostTable() {
        costTableBody.innerHTML = ''; // Clear the table body
        const selectedPromos = getSelectedPromos();

        // For each selected promo type, create a section in the table
        for (const [promoType, count] of Object.entries(selectedPromos)) {
            if (count > 0) {
                // Add a header row for this promo type
                const headerRow = document.createElement('tr');
                const headerCell = document.createElement('th');
                headerCell.colSpan = 2;
                headerCell.textContent = getPromoTypeName(promoType);
                headerRow.appendChild(headerCell);
                costTableBody.appendChild(headerRow);

                // Special handling for promo types that don't have multiple uscite
                if (['supertop', 'highlight', 'etichetta', 'supertopnotte', 'highlightnotte', 'etichettanotte'].includes(promoType)) {
                    const row = document.createElement('tr');
                    const typeCell = document.createElement('td');
                    const priceCell = document.createElement('td');

                    typeCell.textContent = 'Singola uscita';
                    
                    const listinoItem = listinoData.find(item => item.uscita === 1);
                    if (listinoItem) {
                        let price = 0;
                        switch (promoType) {
                            case 'supertop': price = listinoItem.supertop; break;
                            case 'highlight': price = listinoItem.highlight; break;
                            case 'etichetta': price = listinoItem.etichetta; break;
                            case 'supertopnotte': price = listinoItem.supertopnotte; break;
                            case 'highlightnotte': price = listinoItem.highlightnotte; break;
                            case 'etichettanotte': price = listinoItem.etichettanotte; break;
                        }
                        priceCell.textContent = price > 0 ? `${price} €` : '-';
                    }

                    row.appendChild(typeCell);
                    row.appendChild(priceCell);
                    costTableBody.appendChild(row);
                } else {
                    // For standard promo types with multiple uscite (1-20)
                    for (let uscita = 1; uscita <= 20; uscita++) {
                        const listinoItem = listinoData.find(item => item.uscita === uscita);
                        if (listinoItem) {
                            const row = document.createElement('tr');
                            const uscitaCell = document.createElement('td');
                            const priceCell = document.createElement('td');

                            uscitaCell.textContent = `${uscita} ${uscita === 1 ? 'uscita' : 'uscite'}`;
                            
                            let price = 0;
                            switch (promoType) {
                                case '1x1': price = listinoItem.oneXone; break;
                                case '1x3': price = listinoItem.oneXthree; break;
                                case '1x7': price = listinoItem.oneXseven; break;
                                case '10x1': price = listinoItem.tenXone; break;
                                case '10x3': price = listinoItem.tenXthree; break;
                                case '10x7': price = listinoItem.tenXseven; break;
                            }

                            priceCell.textContent = price > 0 ? `${price} €` : '-';
                            
                            if (uscita === count) {
                                row.style.backgroundColor = '#f0f8ff';
                            }

                            row.appendChild(uscitaCell);
                            row.appendChild(priceCell);
                            costTableBody.appendChild(row);
                        }
                    }
                }

                // Add a separator row
                const separatorRow = document.createElement('tr');
                const separatorCell = document.createElement('td');
                separatorCell.colSpan = 2;
                separatorCell.style.height = '20px';
                separatorRow.appendChild(separatorCell);
                costTableBody.appendChild(separatorRow);
            }
        }
    }

    async function calculateTotalCost() {
        // Fetch the listino data if not already loaded
        if (listinoData.length === 0) {
            listinoData = await fetchListinoData();
            if (listinoData.length === 0) {
                console.warn('No listino data available.');
                return;
            }
        }

        const selectedPromos = getSelectedPromos();
        let totalCost = 0;

        // Calculate the total cost
        for (const [promoType, count] of Object.entries(selectedPromos)) {
            if (count > 0) {
                const listinoItem = listinoData.find(item => item.uscita === count);
                if (listinoItem) {
                    switch (promoType) {
                        case '1x1': totalCost += parseFloat(listinoItem.oneXone); break;
                        case '1x3': totalCost += parseFloat(listinoItem.oneXthree); break;
                        case '1x7': totalCost += parseFloat(listinoItem.oneXseven); break;
                        case '10x1': totalCost += parseFloat(listinoItem.tenXone); break;
                        case '10x3': totalCost += parseFloat(listinoItem.tenXthree); break;
                        case '10x7': totalCost += parseFloat(listinoItem.tenXseven); break;
                        case 'supertop': totalCost += parseFloat(listinoItem.supertop); break;
                        case 'highlight': totalCost += parseFloat(listinoItem.highlight); break;
                        case 'etichetta': totalCost += parseFloat(listinoItem.etichetta); break;
                        case 'supertopnotte': totalCost += parseFloat(listinoItem.supertopnotte); break;
                        case 'highlightnotte': totalCost += parseFloat(listinoItem.highlightnotte); break;
                        case 'etichettanotte': totalCost += parseFloat(listinoItem.etichettanotte); break;
                    }
                }
            }
        }

        totalCostElement.textContent = `${totalCost.toFixed(2)} €`;
        updateCostTable();
    }

    // Set up MutationObserver after DOM is loaded
    const observer = new MutationObserver(function(mutations) {
        mutations.forEach(function(mutation) {
            console.log('Mutation detected:', mutation);
            if (mutation.type === 'attributes' && 
                (mutation.attributeName === 'data-highlight' || 
                 mutation.attributeName === 'data-etichetta' ||
                 mutation.attributeName === 'data-supertop' ||
                 mutation.attributeName === 'data-highlightnotte' ||
                 mutation.attributeName === 'data-etichettanotte' ||
                 mutation.attributeName === 'data-supertopnotte')) {
                calculateTotalCost();
            }
        });
    });
    

    // Observe all newpost-panel elements
    document.querySelectorAll('.newpost-panel').forEach(panel => {
        observer.observe(panel, {
            attributes: true,
            attributeFilter: ['data-highlight', 'data-etichetta', 'data-supertop', 
                             'data-highlightnotte', 'data-etichettanotte', 'data-supertopnotte']
        });
    });

    // Also observe dynamically added panels
    const panelContainer = document.querySelector('.newpost-panel');
    if (panelContainer) {
        observer.observe(panelContainer, {
            childList: true,
            subtree: true
        });
    }

    // Add event listeners to checkboxes
    checkboxes.forEach(checkbox => {
        checkbox.addEventListener('change', calculateTotalCost);
    });

    
    // Add event listeners to "+" buttons for 10x1, 10x3, and 10x7
    document.querySelectorAll('.promoPanel .btn-primary').forEach(button => {
        button.addEventListener('click', () => {
            setTimeout(calculateTotalCost, 100);
        });
    });

    // Add event listener to the dropdown button
    toggleTableBtn.addEventListener('click', () => {
        if (costTableContainer.style.display === 'none') {
            costTableContainer.style.display = 'block';
            toggleTableBtn.textContent = 'Nascondi dettagli per più giorni';
        } else {
            costTableContainer.style.display = 'none';
            toggleTableBtn.textContent = 'Mostra dettagli per più giorni';
        }
    });

    // Initial calculation
    calculateTotalCost();
});


    </script>
