    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
function loadWhatsappQR() {
    fetch('/deadline/whatsapp-qr', { credentials: 'same-origin' })
        .then(res => res.json())
        .then(data => {
            // Show QR code if present
            const qrDiv = document.getElementById('qrcode');
            qrDiv.innerHTML = '';
            if (data.qr) {
                new QRCode(qrDiv, {
                    text: data.qr,
                    width: 256,
                    height: 256
                });
            } else {
                qrDiv.textContent = 'QR code non disponibile.';
            }

            // Show status
            const statusSpan = document.getElementById('whatsappStatus');
            if (data.status === 1) {
                statusSpan.textContent = '✅ WhatsApp attivo';
                statusSpan.style.color = 'green';
            } else {
                statusSpan.textContent = '❌ WhatsApp non connesso, scansiona il QR code per connetterti.';
                statusSpan.style.color = 'red';
            }
        })
        .catch(() => {
            document.getElementById('qrcode').textContent = 'Errore nel caricamento del QR code.';
            document.getElementById('whatsappStatus').textContent = '';
        });
}

// Call on page load
document.addEventListener('DOMContentLoaded', loadWhatsappQR);
setInterval(loadWhatsappQR, 10000);
</script>
