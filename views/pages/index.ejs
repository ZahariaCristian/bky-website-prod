<!DOCTYPE html>
<html lang="it">
<head>
    <title>BKY</title>
    <%- include('../partials/head'); %>
</head>
<body>
    <div class="container">
        <div class="row row-app">
            <div class="col-separator col-unscrollable box">
                <div class="col-table">
                    <h1 class="innerAll margin-none border-bottom text-center text-muted-darker" style="font-size: 7em;"><i class="fa fa-lock"></i></h1>
                    <div class="col-table-row">
                        <div class="col-app col-unscrollable">
                            <div class="col-app">
                                <div class="login">
                                    <div class="placeholder text-center">
                                        <div class="separator"></div>
                                    </div>
                                    <div class="panel panel-default col-md-4 col-sm-6 col-sm-offset-3 col-md-offset-4">
                                                    <div class="panel-body">
                                                        <div class="text-center">
                                                            <h1 class="">BKY</h1>
                                                        </div>
                                                <div class="form-group">
                                                    <label for="exampleInputEmail1"><span class="trad">Username</span></label>
                                                    <div class="input-group">
                                                        <span class="input-group-addon"><i class="fa fa-user"></i></span>
                                                        <input name="email" autocomplete="email" id="txtUsername" class="form-control" type="text" value="">
                                                    </div>
                                                    <div class="validation valid-mail">
                                                    <div class="alert-danger" style="padding:2px 8px">validation</div>
                                                        </div>
                                                </div>
                                                <div class="form-group">
                                                    <label for="exampleInputPassword1">Password</label>
                                                    <div class="input-group">
                                                        <span class="input-group-addon"><i class="fa fa-lock"></i></span>
                                                    <input name="password" autocomplete="current-password" id="txtPassword" class="form-control" type="password" value="">
                                                    </div>
                                                    <div class="validation valid-pass">
                                                    <div class="alert-danger" style="padding:2px 8px">validation</div>
                                                        </div>
                                                </div>
                                                <a href="#" onclick="login()" class="btn btn-primary btn-block">Login</a>
                                        </div>
                                    </div>
                                 
                                    </div>
                                    <div class="clearfix"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="loader">
            <img src="/assets/loader.gif" />
        </div>
    <script src="/js/login.js"></script>
</body>
</html>