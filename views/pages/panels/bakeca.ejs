                                        <img id="modalImage" src="" alt="Image to Edit" style="max-width: 100%;">
                                    </div>
                                    <div class="custom-modal-footer">
                                        <button id="saveCropButton" class="custom-modal-save">Salva Anteprima
                                            Bakeca</button>
                                    </div>
                                </div>
                            </div>

                            <div class="widget widget-body-gray widget-after">
                                <div class="widget-head" style="background: #eaeaea;">
                                    <h3 class="heading glyphicons edit" style="margin-left: -10px;"><i></i>Storico
                                        Pubblicazioni</h3>
                                    <span class="text-default pull-right btnCopy">Copia le uscite</span> <a
                                        class="btn btn-xs pull-right btnCopy"><i class="fa fa-copy"
                                            style="font-size: 27px; line-height: 27px;"></i></a>
                                    <span class="text-default pull-right btnCopy">Condividi</span> <a id="btnWhatapp"
                                        class="btn btn-xs pull-right" href="whatsapp://send?text=" target="_blank"><i
                                            class="fa fa-whatsapp" style="font-size: 27px; line-height: 27px;"></i></a>
                                </div>
                                <div class="widget-head">
                                    <div class="col-md-2 col-sm-2">
                                        <div class="row">
                                            <h4 class="heading"> </h4>
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-sm-4">
                                        <div class="row">
                                            <h4 class="heading">Descrizione (città)</h4>
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-sm-4">
                                        <div class="row">
                                            <h4 class="heading" style="float: none;">Stato</h4>
                                        </div>
                                    </div>
                                    <div class="col-md-1 col-sm-1">
                                        <div class="row">
                                            <h4 class="heading" style="float: none;">Pagati Cliente</h4>
                                        </div>
                                    </div>
                                </div>
                                <div class="widget-body" style="padding-top: 0;">
                                    <div class="row">
                                        <div id="rptStorico" class="col-md-12">
                                            <div class="row center rptNoData">Nessun dato rilevato</div>
                                            <div class="rptItemStorico row" data-id="@id@" style="display: none;">
                                                <div class="col-md-2 col-sm-2">
                                                    <a class="btn" onclick="deleteStorico(this, '@id@')"><i
                                                            class="fa fa-times text-danger"></i></a>
                                                    <a class="btn" onclick="copyStorico(this, '@id@')"><i
                                                            class="fa fa-copy text-primary"></i></a>
                                                    <a class="btn btnCondividi" data-id="@id@"
                                                        href="whatsapp://send?text=" target="_blank"><i
                                                            class="fa fa-whatsapp text-primary"></i></a>
                                                </div>
                                                <div class="rptDescription col-md-4 col-sm-4">
                                                    <b>@descrizione@</b> (@città@)
                                                    <div class="col-md-12 dateTimeTop">@orari@</div>
                                                </div>
                                                <div class="col-md-4 col-sm-4">
                                                    <div class="status-actions">
                                                        @stato@
                                                        <a class="btn btn-success btn-xs btnPublishState"
                                                            data-id="@id@">PUBBLICATO</a>
                                                        <a class="btn btn-danger btn-xs btnSuspend"
                                                            onclick="suspendAds(this, '@id@')"
                                                            data-id="@id@">SOSPENDI</a>
                                                        <a class="btn btn-default btn-xs btnDeleteState"
                                                            onclick="deleteAds(this, '@id@')" data-id="@id@">DELETE</a>
                                                    </div>
                                                </div>
                                                <div class="col-md-1 col-sm-1">
                                                    @pagato@
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="lblTitleStorico col-md-12 text-danger"
                                            style="display: none; text-align: center;">
                                            <div class="separator"></div>
                                            <h5 class="strong">Pubblicazioni Sospese</h5>
                                        </div>
                                        <div id="rptStoricoSospesi" class="col-md-12">
                                            <div class="row center rptNoData">Nessun dato rilevato</div>
                                            <div class="rptItemStoricoSospesi row" data-id="@id@"
                                                style="display: none;">
                                                <div class="col-md-2 col-sm-2">
                                                    <a class="btn" onclick="deleteStorico(this, '@id@')"><i
                                                            class="fa fa-times text-danger"></i></a>
                                                </div>
                                                <div class="rptDescription col-md-4 col-sm-4">
                                                    <b>@descrizione@</b> (@città@)
                                                    <div class="col-md-12 dateTimeTop">@orari@</div>
                                                </div>
                                                <div class="col-md-4 col-sm-4">
                                                    <div class="status-actions">
                                                        @stato@
                                                        <a class="btn btn-danger btn-xs btnPublishState"
                                                            data-id="@id@">SOSPESO</a>
                                                        <a class="btn btn-default btn-xs btnDeleteState"
                                                            onclick="deleteAds(this, '@id@')" data-id="@id@">DELETE</a>
                                                    </div>
                                                </div>
                                                <div class="col-md-1 col-sm-1">
                                                    @pagato@
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <button class="btn btn-primary" style="width: 100%; margin-top: 20px;"
                                                onclick="toggleSuspended();" id="btnShowSuspended"><b>MOSTRA
                                                    SOSPESI</b></button>
                                        </div>
                                        <div class="col-md-4">
                                            <a class="btn btn-danger strong" style="width: 100%; margin-top: 20px;"
                                                onclick="suspendPublishedAds(this)"><b>SOSPENDI PUBBLICATI</b></a>
                                        </div>
                                        <div class="col-md-4">
                                            <a class="btn btn-default strong" style="width: 100%; margin-top: 20px;"
                                                onclick="deletePublishedAds(this)"><b>DELETE PUBBLICATI</b></a>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-12">
                                            <a class="btn btn-danger btnSuspendAll strong"
                                                style="width: 100%; margin-top: 20px;"
                                                onclick="suspendOldAds(this)">SOSPENDI SCADUTI</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <footer>
                        <%- include('../../partials/footer'); %>
                    </footer>
            </div>
    </div>

    <div class="loader">
        <img src="/assets/loader.gif" />
    </div>
    <textarea id="txtCopy" class="" style="position: absolute; left: -100000000px"></textarea>
    <script src="/js/panels/categoryConstants.js"></script>
    <script src="/js/panels/bakeca/main.js"></script>
    <script src="/js/panels/bakeca/calendar.js"></script>
    <script src="/js/panels/bakeca/images.js?v=20260527-image-arrows"></script>
    <script src="/js/panels/bakeca/timeslot.js"></script>
    <script src="/js/panels/bakeca/ajax.js"></script>
    <script src="/js/panels/bakeca/history.js"></script>
    <script src="/js/panels/bakeca/utils.js"></script>
</body>

</html>
