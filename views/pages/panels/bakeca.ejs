        <style>
            /* Custom Modal Styles */
            .custom-modal {
                display: none;
                /* Hidden by default */
                position: fixed;
                z-index: 1000;
                left: 0;
                top: 0;
                width: 100%;
                height: 100%;
                overflow: auto;
                background-color: rgba(0, 0, 0, 0.5);
                /* Semi-transparent background */
            }

            .custom-modal-content {
                background-color: #fff;
                margin: 10% auto;
                padding: 20px;
                border: 1px solid #888;
                width: 80%;
                max-width: 800px;
                border-radius: 8px;
            }

            .custom-modal-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                border-bottom: 1px solid #ddd;
                padding-bottom: 10px;
                margin-bottom: 10px;
            }

            .custom-modal-title {
                font-size: 1.5em;
                font-weight: bold;
            }

            .custom-modal-close {
                background: none;
                border: none;
                font-size: 1.5em;
                cursor: pointer;
            }

            .custom-modal-close:hover {
                color: #f00;
            }

            .custom-modal-body {
                margin-bottom: 20px;
            }

            .custom-modal-footer {
                text-align: right;
            }

            .custom-modal-save {
                background-color: #007bff;
                color: #fff;
                border: none;
                padding: 8px 16px;
                border-radius: 4px;
                cursor: pointer;
            }

            .custom-modal-save:hover {
                background-color: #0056b3;
            }

            .promo>.promoPanel,
            .promo>.videochiamata-promo,
            .promo>.premium-promo {
                padding: 12px;
            }

            .servizi-wrapper {
                display: flex;
                flex-direction: row;
                flex-wrap: wrap;
            }

            .servizi-box {
                width: 33%;
            }

            .widget-after {
                display: none;
            }

            .rptItemStorico:nth-child(even) {
                background: #e3e3e3
            }

            .rptItemStorico:nth-child(odd) {
                background: transparent
            }

            .rptItemStorico>div {
                padding: 6px 12px 6px 12px;
            }

            .rptItemStorico>div:first-child {
                padding: 0 !important;
            }

            .rptItemStoricoSospesi:nth-child(even) {
                background: #e3e3e3
            }

            .rptItemStoricoSospesi:nth-child(odd) {
                background: transparent
            }

            .rptItemStoricoSospesi>div {
                padding: 6px 12px 6px 12px;
            }

            .rptItemStoricoSospesi>div:first-child {
                padding: 0 !important;
            }

            .removed .btn-primary {
                display: none;
            }

            .persistent .btn-success {
                display: none;
            }

            .persistent .btn-success.img-move-btn {
                display: inline-block;
            }

            .pic-panel .btn {
                width: 37px;
            }

            .pics.removed {
                display: none;
            }

            .widget.widget-tabs>.widget-head ul li.active {
                background: none !important;
                font-weight: 700;
            }

            .rptItemStorico .btn {
                font-size: 18px;
            }

            .status-actions {
                display: inline-flex;
                align-items: center;
                gap: 6px;
                flex-wrap: wrap;
            }

            .status-actions .btn {
                font-size: 12px !important;
                line-height: 1.2;
            }

            .status-actions h3 {
                margin: 0;
            }

            .event-container {
                display: none !important;
            }

            .newpost-wrapper>button {
                margin-left: 12px;
                height: 34px !important;
            }

            .promoFree .btnPremiumCam {
