<!DOCTYPE html>
<html lang="it" class="sidebar sidebar-discover">
<head>
    <title>BKY - Utenti</title>
    <%- include('../partials/head'); %>
    <style>
        .control-label{
            margin-top: 7px;
        }
        .rptItemUsers:nth-child(even) {background: #e3e3e3}
        .rptItemUsers:nth-child(odd) {background: transparent}
    </style>
</head>
<body class="scripts-async wysihtml5-supported menu-left-visible">
    <div class="container-fluid menu-hidden" style="visibility: visible;">
        <%- include('../partials/menu'); %>
        <div id="content">
            <%- include('../partials/header'); %>
            <h1 style="margin-bottom: 20px;">Lista Utenti</h1>
            <div class="innerLR">
                <div class="widget widget-body-gray">
                    <div class="widget-head">
                        <div class="col-md-1 col-sm-1">
                            <div class="row"><h4 class="heading"> </h4></div>
                        </div>
                        <div class="col-md-3 col-sm-3">
                            <div class="row"><h4 class="heading">Nome Utente</h4></div>
                        </div>
                        <div class="col-md-4 col-sm-4">
                            <div class="row"><h4 class="heading">Mail</h4></div>
                        </div>
                        <div class="col-md-2 col-sm-2">
                            <div class="row"><h4 class="heading">Ruolo</h4></div>
                        </div>
                        <div class="col-md-2 col-sm-2">
                            <div class="row"><h4 class="heading">Attivo</h4></div>
                        </div>
                    </div>
                    <div class="widget-body">
                        <div class="row">
                            <div id="rptUsers" class="col-md-12">
                                <div class="row center rptNoData">Nessun dato rilevato</div>
                                <div class="rptItemUsers row edited" style="display: none;">
                                    <input type="hidden" fieldName="OID" value="0" />
                                    <div class="col-md-1 col-sm-1">
                                        <a class="btn" href="/user.html?u=@OID@"><i class="fa fa-edit"></i></a>
                                    </div>
                                    <div class="col-md-3 col-sm-3">
                                        <label class="control-label" fieldName="userName"></label>
                                    </div>
                                    <div class="col-md-4 col-sm-4">
                                        <label class="control-label" fieldName="mail"></label>
                                    </div>
                                    <div class="col-md-2 col-sm-2">
                                        <label class="control-label" fieldName="tblUserRole.tblRole.name"></label>
                                    </div>
                                    <div class="col-md-2 col-sm-2">
                                        <input type="checkbox" disabled class="control-checkbox" fieldName="isActive" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>         
            <footer>
                <%- include('../partials/footer'); %>
            </footer>
        </div>
    </div>
            
    <script src="/js/users.js"></script>
</body>
</html>
