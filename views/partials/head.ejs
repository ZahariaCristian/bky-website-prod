<style>
    .loader{
        display: none;
        position: fixed;
        z-index: 1000;
        width: 100vw;
        height: 100vh;
        top:0;
        background: white;
        opacity: 0.5;
    }
    .loader > img{
        position: fixed;
        z-index: 1001;
        top: calc(50% - 58px);
        left: calc(50% - 58px);
    }
</style>
<script>
    function toggleLoader(){
        if($(".loader").is(":visible")){
          $(".loader").hide();
        }else{
          $(".loader").show();
        }    
      } 
</script>